APP_NAME=Agentic Enterprise API RAG Backend
ENVIRONMENT=local
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

OLLAMA_BASE_URL=http://172.16.111.209:8080
OLLAMA_LLM_MODEL=llama3:8b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_TIMEOUT_CONNECT_SECONDS=15
OLLAMA_TIMEOUT_READ_SECONDS=45
OLLAMA_TIMEOUT_WRITE_SECONDS=15
OLLAMA_TIMEOUT_POOL_SECONDS=5
OLLAMA_RETRY_COUNT=2
OLLAMA_RETRY_DELAY_SECONDS=1.5

# Provider selection (POC stability): set OpenAI for now, keep Ollama available
OPENAI_API_KEY=
LLM_PROVIDER=ollama
EMBEDDING_PROVIDER=ollama
OPENAI_LLM_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=enterprise_api_docs
QDRANT_COLLECTION_OPENAI=enterprise_api_docs_openai
EMBEDDING_DIM=768

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=agentic_api_rag
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password
DATABASE_URL=postgresql+psycopg2://postgres:your_password@localhost:5432/agentic_api_rag

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0

NEO4J_ENABLED=false
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password

JWT_SECRET_KEY=change_this_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
ENABLE_SUGGESTED_FOLLOW_UPS=true
SUGGESTED_FOLLOW_UP_COUNT=3
